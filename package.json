{
	"name": "PixelVivid",
	"version": "3.1.7",
	"private": true,
	"author": {
		"name": "Pixelated Technologies",
		"url": "https://www.pixelated.tech/"
	},
	"scripts": {
		"dev": "npm run clean && NODE_OPTIONS='--inspect' next dev -p 3005 --experimental-https",
		"build": "npm run clean && NODE_ENV=production next build",
		"start": "npm run clean && next build && next start",
		"lint": "eslint --fix",
		"clean": "rm -rf .next && rm -rf out",
		"generate-site-images": "node ./node_modules/@pixelated-tech/components/dist/scripts/generate-site-images.js",
		"config:vault": "npx tsx ./node_modules/@pixelated-tech/components/dist/scripts/config-vault.ts",
		"config:encrypt": "npm run config:vault -- encrypt src/app/config/pixelated.config.json",
		"config:decrypt": "npm run config:vault -- decrypt src/app/config/pixelated.config.json.enc",
		"release:prep": "npm run update && npm run lint && npm run build",
		"release": "./node_modules/@pixelated-tech/components/dist/scripts/release.sh",
		"update": "bash node_modules/@pixelated-tech/components/dist/scripts/update.sh"
	},
	"dependencies": {
		"@pixelated-tech/components": "^3.14.2",
		"date-fns": "^4.1.0",
		"globals": "^17.4.0",
		"html-entities": "^2.6.0",
		"md5": "^2.3.0",
		"next": "^16.2.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "9.39.4",
		"@eslint/json": "^1.2.0",
		"@next/eslint-plugin-next": "^16.2.2",
		"@next/third-parties": "^16.2.2",
		"@types/estree": "^1.0.8",
		"@types/node": "^25.5.0",
		"@types/prop-types": "^15.7.15",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"css-loader": "^7.1.4",
		"eslint": "9.39.4",
		"eslint-config-next": "^16.2.2",
		"eslint-plugin-react": "^7.37.5",
		"sass": "^1.98.0",
		"sass-loader": "^16.0.7",
		"style-loader": "^4.0.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0"
	},
	"overrides": {}
}
